;; Tab-completion for programming modes.
(defun indent-or-expand (arg)
  "Either indent or expand, depending on context."
  (interactive "*P")
  (if (and
       (or (bobp) (= ?w (char-syntax (char-before))))
       (or (eobp) (not (= ?w (char-syntax (char-after))))))
      (hippie-expand arg)
    (indent-according-to-mode)))
(defun my-tab-fix ()
  (local-set-key [tab] 'indent-or-expand))

;; Abbreviations.
(setq save-abbrevs t)
(setq abbrev-verbose t)
(when (file-exists-p "~/.emacs.d/abbrev_defs")
  (load "~/.emacs.d/abbrev_defs"))


(defun hilite-todos ()
  (highlight-lines-matching-regexp
   "\\<\\(FIXME\\|WRITEME\\|WRITEME!\\|TODO\\|BUG\\):?"
   'hi-green-b))

(defun my-prog-config ()
  "Set minor modes and other config for all programming related modes."
  (abbrev-mode 1)
  (display-line-numbers-mode 1)
  (pretty-greek)
  (hilite-todos)
  (when (fboundp 'git-gutter-mode)
    (git-gutter-mode 1)
    (set-face-foreground 'git-gutter-fr:deleted "red"))
  (my-tab-fix)
  (show-paren-mode 1)
  (flyspell-prog-mode)
  (when (fboundp 'rainbow-delimiters-mode)
    (rainbow-delimiters-mode 1))
  (setq time-stamp-active t
        time-stamp-line-limit 10
        time-stamp-format "%02d-%02m-%04y %02H:%02M:%02S (%u)")
  (add-hook 'before-save-hook 'time-stamp nil t)
  (font-lock-add-keywords nil
                          '(("^[^\n]\\{80\\}\\(.*\\)$" 1 font-lock-warning-face t))))


(add-hook 'actionscript-mode-hook 'my-prog-config)
