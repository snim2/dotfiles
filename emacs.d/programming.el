;;; SML: display "fn" as λ.
(defun pretty-fns ()
  (font-lock-add-keywords
   nil `(("(\\(fn\\>\\)"
          (0 (progn (compose-region (match-beginning 1) (match-end 1) ?λ)
                    nil))))))
(add-hook 'sml-mode-hook 'pretty-fns)

;;; Actionscript 3.
(setq auto-mode-alist
      (cons '("\\.as$" . actionscript) auto-mode-alist))

;;; Maxima.
(setq auto-mode-alist (cons '("\\.max" . maxima-mode) auto-mode-alist))
(autoload 'maxima "maxima" "Running Maxima interactively" t)
(autoload 'maxima-mode "maxima" "Maxima editing mode" t)

;;; Java: insert a public class definition into any new .java file.
(defun snim2-java-insert-public-class ()
  (let ((filename (buffer-file-name (current-buffer))))
    (when (and (= 1 (point-max)) filename)
      (let ((classname (file-name-sans-extension
                        (file-name-nondirectory filename))))
        (skeleton-insert
         '(nil "public class " classname " {\n"
               > _
               "\n}"))))))

(defun snim2-java-setup ()
  (c-set-style "k&r")
  (setq c-basic-offset 4)
  (c-set-offset 'case-label '+))

(add-hook 'java-mode-hook 'snim2-java-setup)

;;; Python.
(setq gud-pdb-command-name "python3 -m pdb")

(defun snim2-python-setup ()
  (define-key python-mode-map "\C-m" 'newline-and-indent)
  (eldoc-mode 1)
  (setq c-basic-offset 4)
  (setq python-indent-offset 4))

(add-hook 'python-mode-hook 'snim2-python-setup)

(defun python-2to3 ()
  "Convert current buffer from python 2 to python 3.
   This command calls python3's script 2to3.
   A backup will be generated by 2to3 and named FILENAME.bak."
  (interactive)
  (let* ((fName (buffer-file-name))
         (fSuffix (file-name-extension fName)))
    (when (buffer-modified-p)
      (when (y-or-n-p "Buffer modified. Do you want to save first?")
        (save-buffer)))
    (if (or (string-equal fSuffix "py") (string-equal fSuffix "py3"))
        (progn
          (shell-command (format "2to3 -w %s" fName))
          (revert-buffer "IGNORE-AUTO" "NOCONFIRM" "PRESERVE-MODES"))
      (error "file \"%s\" doesn't end in \".py\" or \".py3\"." fName))))

